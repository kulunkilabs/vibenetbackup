DATABASE_URL=sqlite:///./vibenetbackup.db
SECRET_KEY=change-me-to-a-random-secret-key
BACKUP_DIR=./backups
OXIDIZED_URL=http://localhost:8888
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=5005

# Authentication (change these!)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme-strong-password

# CORS - comma-separated list of allowed origins
# Secure (localhost only):
CORS_ORIGINS=http://localhost:5005,http://127.0.0.1:5005

# Wide range (development/testing only - allows any origin):
# CORS_ORIGINS=*

# Wide range (specific IP patterns - adjust to your network):
# CORS_ORIGINS=http://localhost:5005,http://127.0.0.1:5005,http://0.0.0.0:5005,http://192.168.0.0/16,http://10.0.0.0/8,http://172.16.0.0/12
